<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Validation"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- PAN Card Input (Forces uppercase/numbers, caps length via maxLength) -->
    <EditText
        android:id="@+id/etPanCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="PAN Card Number (10 Alphanumeric)"
        android:inputType="textCapCharacters"
        android:maxLength="10"
        android:layout_marginBottom="16dp"/>

    <!-- Pincode Input (Forces numeric keyboard, caps length via maxLength) -->
    <EditText
        android:id="@+id/etPincode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="City Pincode (6 Digits)"
        android:inputType="number"
        android:maxLength="6"
        android:layout_marginBottom="24dp"/>

    <!-- Validate Button -->
    <Button
        android:id="@+id/btnValidate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Validate"
        android:layout_marginBottom="16dp"/>

    <!-- Status Output -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_gravity="center"
        android:textAlignment="center"
        android:textStyle="bold"/>

</LinearLayout>